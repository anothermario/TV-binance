# Binance API credentials (generate at https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Secret passphrase — must match the value in your TradingView alert message
WEBHOOK_PASSPHRASE=MY_SECRET_PHRASE

# Port the Flask server listens on (default: 10000 for Render)
PORT=10000
